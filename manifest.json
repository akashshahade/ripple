{
  "manifest_version": 3,
  "name": "Ripple — Screen Break & Hydrate Nudge",
  "version": "1.0.0",
  "description": "Gentle, well-designed reminders to stretch, hydrate, and rest your eyes without breaking your flow.",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ripple"
  }
}
